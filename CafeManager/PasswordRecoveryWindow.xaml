<Window x:Class="RestaurantSystem.PasswordRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ВОССТАНОВЛЕНИЕ ПАРОЛЯ" Height="350" Width="400" WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ВОССТАНОВЛЕНИЕ ПАРОЛЯ" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>
        <TextBlock Grid.Row="1" Text="Введите Email или телефон, привязанный к аккаунту" FontSize="11" HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="Gray"/>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Email / Телефон:"/>
            <TextBox Height="25" Margin="0,2"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Новый пароль:"/>
            <TextBox Height="25" Margin="0,2"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,20">
            <TextBlock Text="Подтверждение:"/>
            <TextBox Height="25" Margin="0,2"/>
        </StackPanel>

        <Button Grid.Row="5" Content="ВОССТАНОВИТЬ" Width="150" Height="35" Background="#555555" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Top"/>
    </Grid>
</Window>