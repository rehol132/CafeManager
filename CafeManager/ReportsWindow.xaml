<Window x:Class="RestaurantSystem.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ОТЧЁТЫ И АНАЛИТИКА" Height="700" Width="900" WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CCCCCC" Padding="10">
            <TextBlock Text="ОТЧЁТЫ И АНАЛИТИКА" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10">
            <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
            <TextBox Text="Текущая смена" Width="120" Height="25" Margin="0,0,5,0"/>
            <TextBlock Text="С:" VerticalAlignment="Center" Margin="5,0"/>
            <DatePicker SelectedDate="2026-03-20" Width="120" Margin="0,0,5,0"/>
            <TextBlock Text="По:" VerticalAlignment="Center" Margin="5,0"/>
            <DatePicker SelectedDate="2026-03-20" Width="120"/>
        </StackPanel>

        <TabControl Grid.Row="2" Margin="0,10">
            <TabItem Header="Выручка">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ВЫРУЧКА ЗА ПЕРИОД" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="Общая выручка: 45 670 ₽"/>
                            <TextBlock Text="Наличные: 18 450 ₽"/>
                            <TextBlock Text="Карта: 27 220 ₽"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="ТОП-5 ПОПУЛЯРНЫХ БЛЮД" FontWeight="Bold" Margin="0,0,0,5"/>
                            <TextBlock Text="1. Капучино - 45 заказов"/>
                            <TextBlock Text="2. Цезарь с курицей - 38 заказов"/>
                            <TextBlock Text="3. Борщ - 32 заказа"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="РАСХОД ПРОДУКТОВ" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DataGrid AutoGenerateColumns="False" Height="150">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Продукт" Width="*"/>
                                    <DataGridTextColumn Header="Ед.изм." Width="60"/>
                                    <DataGridTextColumn Header="Остаток" Width="80"/>
                                    <DataGridTextColumn Header="Закупка" Width="80"/>
                                    <DataGridTextColumn Header="Статус" Width="60"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Популярность блюд"/>
            <TabItem Header="Эффективность"/>
            <TabItem Header="Расход продуктов"/>
        </TabControl>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button Content="Сформировать" Width="130" Height="30" Background="#555555" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Экспорт в Excel" Width="120" Height="30" Background="#555555" Foreground="White" Margin="0,0,5,0"/>
            <Button Content="Печать" Width="80" Height="30" Background="#555555" Foreground="White"/>
        </StackPanel>

        <Button Grid.Row="3" Content="Назад" Width="80" Height="30" Background="#555555" Foreground="White" HorizontalAlignment="Right"/>
    </Grid>
</Window>