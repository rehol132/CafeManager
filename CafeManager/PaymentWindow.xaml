<Window x:Class="RestaurantSystem.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ОПЛАТА ЗАКАЗА №3" Height="600" Width="600" WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CCCCCC" Padding="10">
            <TextBlock Text="ОПЛАТА ЗАКАЗА №3" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,10">
            <StackPanel>
                <TextBlock Text="Столик: №3"/>
                <TextBlock Text="Официант: Иванова Е.П."/>
                <TextBlock Text="Дата: 20.03.2026, 14:30"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="2" Margin="0,10">
            <StackPanel>
                <DataGrid AutoGenerateColumns="False" Margin="0,0,0,10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Товар" Width="*"/>
                        <DataGridTextColumn Header="Кол-во" Width="60"/>
                        <DataGridTextColumn Header="Цена" Width="80"/>
                        <DataGridTextColumn Header="Сумма" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="ИТОГО: 1770 ₽" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right" Margin="0,10"/>

                <TextBlock Text="СПОСОБ ОПЛАТЫ:" FontWeight="Bold" Margin="0,10,0,5"/>

                <RadioButton Content="НАЛИЧНЫЕ" GroupName="Payment" Margin="0,0,0,5"/>
                <TextBlock Text="Принять наличные, выдать сдачу" Margin="20,0,0,5" Foreground="Gray" FontSize="11"/>

                <RadioButton Content="БАНКОВСКАЯ КАРТА" GroupName="Payment" Margin="0,5,0,5"/>
                <TextBlock Text="Оплата через терминал" Margin="20,0,0,10" Foreground="Gray" FontSize="11"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Чаевые:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="0" Width="80" Height="25"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="ОПЛАТИТЬ" Width="120" Height="40" Background="#555555" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Печать чека" Width="120" Height="40" Background="#555555" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Отмена" Width="100" Height="40" Background="#555555" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>