<Window x:Class="RestaurantSystem.CreateOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СОЗДАНИЕ ЗАКАЗА" Height="600" Width="700" WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CCCCCC" Padding="10">
            <TextBlock Text="СОЗДАНИЕ ЗАКАЗА | Столик №3" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,10">
            <StackPanel>
                <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10">
                    <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Блюдо" Width="*"/>
                            <DataGridTextColumn Header="Цена" Width="80"/>
                            <DataGridTextColumn Header="Время" Width="80"/>
                            <DataGridTextColumn Header="Категория" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,10">
                    <DataGrid AutoGenerateColumns="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Текущий заказ" Width="*"/>
                            <DataGridTextColumn Header="Кол-во" Width="60"/>
                            <DataGridTextColumn Header="Цена" Width="80"/>
                            <DataGridTextColumn Header="Сумма" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <TextBlock Text="ИТОГО: 1770 ₽" FontWeight="Bold" FontSize="16" HorizontalAlignment="Right" Margin="0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Комментарий:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBox Text="Без лука, соус отдельно" Width="300" Height="25"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Button Content="В заказ" Width="100" Height="35" Background="#555555" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="На кухню" Width="100" Height="35" Background="#555555" Foreground="White" Margin="0,0,5,0"/>
                <Button Content="Оплатить" Width="100" Height="35" Background="#555555" Foreground="White" Margin="0,0,5,0"/>
            </StackPanel>

            <Button Content="Назад" Width="80" Height="35" Background="#555555" Foreground="White" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>