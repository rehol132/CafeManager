<Window x:Class="RestaurantSystem.TableLayoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СХЕМА СТОЛИКОВ" Height="700" Width="900" WindowStartupLocation="CenterScreen" Background="White">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#CCCCCC" Padding="10">
            <TextBlock Text="СХЕМА СТОЛИКОВ | Официант: Иванова Е.П." FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Padding="10" Margin="0,5">
            <TextBlock Text="Свободен | Занят | Бронь"/>
        </Border>

        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Столик 1 -->
            <Border Grid.Row="0" Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="0,27,10,67" Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 1" FontWeight="Bold"/>
                    <TextBlock Text="2 места"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 2 -->
            <Border Grid.Row="0" Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="0,27,10,67" Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 2" FontWeight="Bold"/>
                    <TextBlock Text="2 места"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 3 -->
            <Border Grid.Row="0" Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="0,27,10,67" Background="#555555">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 3" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="4 места" Foreground="White"/>
                    <TextBlock Text="Занят" Foreground="White"/>
                    <TextBlock Text="Заказ №3" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Столик 4 -->
            <Border Grid.Row="0" Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Margin="0,27,10,67" Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 4" FontWeight="Bold"/>
                    <TextBlock Text="4 места"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 5 -->
            <Border Grid.Row="0" Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Margin="0,27,10,67" Background="White">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 5" FontWeight="Bold"/>
                    <TextBlock Text="6 мест"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 6 -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5,10,5,83" Background="#555555" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 6" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="6 мест" Foreground="White"/>
                    <TextBlock Text="Занят" Foreground="White"/>
                    <TextBlock Text="Заказ №2" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Столик 7 -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5,10,5,83" Background="White" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 7" FontWeight="Bold"/>
                    <TextBlock Text="6 мест"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 8 -->
            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Margin="5,10,5,83" Background="White" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 8" FontWeight="Bold"/>
                    <TextBlock Text="2 места"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>

            <!-- Столик 9 -->
            <Border Grid.Column="3" BorderBrush="Gray" BorderThickness="1" Margin="5,10,5,83" Background="#888888" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 9" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="2 места" Foreground="White"/>
                    <TextBlock Text="Бронь" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Столик 10 -->
            <Border Grid.Column="4" BorderBrush="Gray" BorderThickness="1" Margin="5,10,5,83" Background="White" Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Столик 10" FontWeight="Bold"/>
                    <TextBlock Text="4 места"/>
                    <TextBlock Text="Свободен" Foreground="Green"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Новый заказ" Width="100" Height="35" Background="#555555" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Обновить" Width="100" Height="35" Background="#555555" Foreground="White" Margin="0,0,10,0"/>
            <Button Content="Выход" Width="80" Height="35" Background="#555555" Foreground="White" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>